generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  discordId     String   @id
  robloxNick    String
  robloxId      String   @unique
  firstName     String
  lastName      String
  dob           String
  gender        String
  citizenship   String
  citizenNumber String
  pocket        Int      @default(0)
  bank          Int      @default(0)
  lastWork      DateTime?
  lastExtra     DateTime?
  bannedUntil   DateTime?
  isPermBanned  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PendingUpdate {
  id             Int      @id @default(autoincrement())
  discordId      String
  newRobloxNick  String
  newRobloxId    String
  newFirstName   String
  newLastName    String
  newDob         String
  newGender      String
  newCitizenship String
  createdAt      DateTime @default(now())
}

model PendingInvalidation {
  id        Int      @id @default(autoincrement())
  discordId String
  createdAt DateTime @default(now())
}

model BanLog {
  id                 String    @id @default(cuid())
  playerNick         String
  moderatorDiscordId String?
  channelId          String
  messageId          String
  reason             String    @default("Brak powodu")
  bannedUntil        DateTime?
  isPermBan          Boolean   @default(false)
  unbannedAt         DateTime?
  unbanModDiscordId  String?
  createdAt          DateTime  @default(now())
}

model TrackedAction {
  id            String   @id @default(cuid())
  erlcTimestamp Int      @unique
  createdAt     DateTime @default(now())
}

model Inventory {
  id        Int      @id @default(autoincrement())
  discordId String
  itemKey   String
  itemName  String
  type      String
  roleId    String?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([discordId])
}

model FineLog {
  id                 String   @id @default(cuid())
  citizenId          String
  playerNick         String
  officerDiscordId   String
  reason             String
  amount             Int
  createdAt          DateTime @default(now())
}

model ArrestLog {
  id                 String   @id @default(cuid())
  citizenId          String
  playerNick         String
  officerDiscordId   String
  reason             String
  time               Int      // e.g. minutes or months
  createdAt          DateTime @default(now())
}

model Vehicle {
  id                 String   @id @default(cuid())
  ownerId            String   // Discord ID właściciela
  ownerName          String   // Imię i Nazwisko z Citizen
  brand              String
  model              String
  plate              String   @unique // Autogenerowane (np. BI 12345)
  imageUrl           String   // URL do zdjęcia auta
  createdAt          DateTime @default(now())

  @@index([ownerId])
  @@index([plate])
}

model PendingVehicle {
  id                 Int      @id @default(autoincrement())
  ownerId            String
  brand              String   @default("")
  model              String   @default("")
  imageUrl           String
  storageMessageId   String?  // ID wiadomości w "cloud storage" do usunięcia przy odrzuceniu
  aiConfidence       Int      @default(0)
  aiLabel            String   @default("")
  createdAt          DateTime @default(now())
}

model WantedPerson {
  id               String   @id @default(cuid())
  targetNick       String   @unique
  robloxId         String? 
  reason           String
  officerDiscordId String
  messageId        String?  // ID wiadomości na kanale #poszukiwani
  createdAt        DateTime @default(now())
}

model WebSession {
  token         String   @id
  discordId     String
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  lastHeartbeat DateTime @default(now())
}

model ModerationShift {
  id               String   @id @default(cuid())
  moderatorId      String
  startTime        DateTime @default(now())
  endTime          DateTime?
  durationMinutes  Int?
}
