generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  discordId     String   @id
  robloxNick    String
  robloxId      String   @unique
  firstName     String
  lastName      String
  dob           String
  gender        String
  citizenship   String
  citizenNumber String
  pocket        Int      @default(0)
  bank          Int      @default(0)
  lastWork      DateTime?
  lastExtra     DateTime?
  bannedUntil   DateTime?
  isPermBanned  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  punishments   Punishment[]
}

enum PunishmentType {
  KICK
  BAN
  PERMBAN
}

model Punishment {
  id          Int            @id @default(autoincrement())
  citizenId   String
  citizen     Citizen        @relation(fields: [citizenId], references: [discordId])
  type        PunishmentType
  reason      String
  duration    String?        // np. "24h"
  messageId   String?        // ID wiadomości na Discordzie
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?
}

model AuditLogState {
  id                    Int      @id @default(1)
  lastProcessedTimestamp DateTime @default(now())
}

model PendingUpdate {
  id             Int      @id @default(autoincrement())
  discordId      String
  newRobloxNick  String
  newRobloxId    String
  newFirstName   String
  newLastName    String
  newDob         String
  newGender      String
  newCitizenship String
  createdAt      DateTime @default(now())
}

model PendingInvalidation {
  id        Int      @id @default(autoincrement())
  discordId String
  createdAt DateTime @default(now())
}
