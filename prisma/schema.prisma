generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  discordId     String   @id
  robloxNick    String
  robloxId      String   @unique
  firstName     String
  lastName      String
  dob           String
  gender        String
  citizenship   String
  citizenNumber String
  pocket        Int      @default(0)
  bank          Int      @default(0)
  lastWork      DateTime?
  lastExtra     DateTime?
  bannedUntil   DateTime?
  isPermBanned  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PendingUpdate {
  id             Int      @id @default(autoincrement())
  discordId      String
  newRobloxNick  String
  newRobloxId    String
  newFirstName   String
  newLastName    String
  newDob         String
  newGender      String
  newCitizenship String
  createdAt      DateTime @default(now())
}

model PendingInvalidation {
  id        Int      @id @default(autoincrement())
  discordId String
  createdAt DateTime @default(now())
}

model BanLog {
  id                 String    @id @default(cuid())
  playerNick         String
  moderatorDiscordId String?
  channelId          String
  messageId          String
  reason             String    @default("Brak powodu")
  bannedUntil        DateTime?
  isPermBan          Boolean   @default(false)
  unbannedAt         DateTime?
  unbanModDiscordId  String?
  createdAt          DateTime  @default(now())
}

model TrackedAction {
  id            String   @id @default(cuid())
  erlcTimestamp Int      @unique
  createdAt     DateTime @default(now())
}
