generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Citizen {
  discordId     String   @id
  robloxNick    String
  robloxId      String
  firstName     String
  lastName      String
  dob           String
  gender        String
  citizenship   String
  citizenNumber String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PendingUpdate {
  id             Int      @id @default(autoincrement())
  discordId      String
  newRobloxNick  String
  newRobloxId    String
  newFirstName   String
  newLastName    String
  newDob         String
  newGender      String
  newCitizenship String
  createdAt      DateTime @default(now())
}

model PendingInvalidation {
  id        Int      @id @default(autoincrement())
  discordId String
  createdAt DateTime @default(now())
}

